# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional: Gemini call resilience (503 / rate limits / transient network)
# GEMINI_MAX_RETRIES=5
# GEMINI_RETRY_BASE_MS=2000
# GEMINI_RETRY_MAX_MS=45000

# Optional: FRED API key for finance baseline feed (series STLFSI4)
# FRED_API_KEY=your_fred_api_key

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
VITE_APP_URL="MY_APP_URL"

# LINE LIFF ID: Required for LINE integration.
# Obtain this from the LINE Developers Console.
VITE_LIFF_ID=

# Access: public (default, anyone) | google (Google Sign-In for /api/* except /api/auth/*)
# AUTH_MODE=public
# AUTH_MODE=google
# GOOGLE_OAUTH_CLIENT_ID=your.apps.googleusercontent.com
# Optional: restrict to domains (comma-separated), e.g. mycompany.com,.gserviceaccount.com
# GOOGLE_ALLOWED_DOMAINS=

# Optional: limit Gemini deep-dive abuse (per client IP, sliding window)
# DEEP_DIVE_MAX_PER_MINUTE=20
# DEEP_DIVE_WINDOW_MS=60000

# Background intelligence loop (Gemini + feeds). Initial scan always runs once on startup.
# TACTICAL_PULSE_MS=300000
# DISABLE_TACTICAL_PULSE=true

# Server ingest buffer: max rows in globalState.insights (first tank). Clamped 10–500; default 50.
# INSIGHTS_BUFFER_MAX=50

# GDACS RSS often blocks or times out; reduce console spam (ms between warnings, default 30m)
# GDACS_FAILURE_LOG_COOLDOWN_MS=1800000
